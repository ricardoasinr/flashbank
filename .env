# =============================================================================
# FlashBank - Environment Variables
# WARNING: Solo desarrollo local. No usar en producción.
#
# Importante: no uses # ni $ sin comillas en contraseñas; Docker Compose y
# muchos parsers .env truncan el valor en el primer # o expanden $variable.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL - Transactions (postgres-transactions :5433)
# POSTGRES_DB / POSTGRES_USER / POSTGRES_PASSWORD -> imagen oficial postgres
# -----------------------------------------------------------------------------
POSTGRES_TX_DB=flashbank_transactions
POSTGRES_TX_USER=flashbank_tx_user
POSTGRES_TX_PASSWORD=DevTx_7fK9mP2qL8vN4wR6yT1zX3bH5cJ0fG9dS

# -----------------------------------------------------------------------------
# PostgreSQL - Accounts (postgres-accounts :5434)
# -----------------------------------------------------------------------------
POSTGRES_ACC_DB=flashbank_accounts
POSTGRES_ACC_USER=flashbank_acc_user
POSTGRES_ACC_PASSWORD=DevAcc_4nM8kP2qW7vR1yT5zX9bH3cJ6fG0dS8aL

# -----------------------------------------------------------------------------
# MongoDB - Read Model / historial (CQRS)
# Nombre de la base de datos: mongodb-history (solo aplica en el primer init;
# si cambias el nombre, borra el volumen flashbank-mongo-data y vuelve a levantar).
# Semilla: en BD mongodb-history, colección history (6 docs, source=docker-seed), alineada
# al esquema lógico de transacciones (Deposit/Withdrawal, estados Pending/Completed/Failed).
# Correr seed manualmente (con mongodb levantado): ./init/run-mongo-seed.sh
#
# Puerto en tu Mac para conectar Compass / apps al contenedor (no uses 27017 si
# tienes MongoDB instalado con Homebrew: ambos competían y Compass hablaba con el
# Mongo equivocado → "Authentication failed").
MONGO_HOST_PORT=27018
#
# DataGrip / IntelliJ: Host 127.0.0.1  Puerto MONGO_HOST_PORT (27018)
#   User: flashbank_admin   Password: MONGO_INITDB_ROOT_PASSWORD
#   Authentication database: admin
#
# Compass: pega MONGODB_URI (usa puerto 27018). TLS/SSL: desactivado.
# -----------------------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=flashbank_admin
MONGO_INITDB_ROOT_PASSWORD=DevMongo_9kLm2pQ8vN4wR7yT1zX6bH3cJ5fG0dS
MONGO_INITDB_DATABASE=mongodb-history

# authSource para clientes (usuario root vive en la BD admin)
MONGO_AUTH_SOURCE=admin

# Alias opcionales para apps (misma contraseña que root de Mongo)
MONGO_PASS=DevMongo_9kLm2pQ8vN4wR7yT1zX6bH3cJ5fG0dS

# URI: Compass / apps (si cambias la contraseña, actualiza también esta línea)
# authMechanism=SCRAM-SHA-256 evita ambigüedad con clientes recientes.
MONGODB_URI=mongodb://flashbank_admin:DevMongo_9kLm2pQ8vN4wR7yT1zX6bH3cJ5fG0dS@127.0.0.1:27018/mongodb-history?authSource=admin&directConnection=true&authMechanism=SCRAM-SHA-256

# -----------------------------------------------------------------------------
# LocalStack (SQS/SNS)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
